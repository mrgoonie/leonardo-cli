{
  "name": "leonardo-cli",
  "version": "1.2.0",
  "description": "Leonardo.Ai CLI — generate images, videos, and more from your terminal. AI-agent and human friendly.",
  "type": "module",
  "bin": {
    "leonardo": "./dist/cli.js",
    "leo": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "leonardo": "bun src/cli.ts",
    "dev": "bun src/cli.ts",
    "build": "bun build src/cli.ts --target=node --outfile=dist/cli.js --minify && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "leonardo",
    "leonardo-ai",
    "cli",
    "image-generation",
    "ai",
    "agent"
  ],
  "author": "mrgoonie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrgoonie/leonardo-cli.git"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20"
  }
}
